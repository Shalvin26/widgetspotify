{
  "name": "player",
  "version": "1.0.0",
  "description": "Spotify notch player",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.15.2",
    "express": "^5.2.1",
    "menubar": "^9.4.0"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.yourname.player",
    "productName": "Player",
    "files": [
      "**/*",
      "!node_modules/.cache"
    ],
    "mac": {
      "target": "dmg",
      "icon": "assets/icon-512.png"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icons8-sound-cloud-24.ico"
    }
  }
}